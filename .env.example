# ─────────────────────────────────────────────────────────────────────
# CEO Assistant — Environment Variables
# Kopírujte tento soubor jako .env a vyplňte hodnoty
# NIKDY nesdílejte .env soubor (přidejte ho do .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=váš_bot_token_zde
TELEGRAM_CHAT_ID=vaše_chat_id_zde

# ── Anthropic API (pro lead research) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-váš_klíč_zde

# ── Google Sheets ─────────────────────────────────────────────────────
# Sheet ID z URL: https://docs.google.com/spreadsheets/d/[TOTO]/edit
SHEETS_ID=váš_sheets_id_zde
SHEETS_TAB=Leads
GOOGLE_CREDS_JSON=./service_account.json

# ── Gmail (pro ukládání draftů) ───────────────────────────────────────
GMAIL_TOKEN_JSON=./gmail_token.json
